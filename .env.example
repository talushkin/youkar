# Public URL where UPay should return after payment (include /after-payment)
NEXT_PUBLIC_RETURN_URL=https://youkar.vercel.app/after-payment

# Optional: enable Google button on after-payment page
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Backend to receive pending queue writes
BACKEND_BASE_URL=https://be-tan-theta.vercel.app

# Backend endpoint for checking ready CDN links by videoId
BACKEND_CDN_PATH=/api/cdn-links

# Optional bearer used by your backend /api/pending
API_BEARER=
